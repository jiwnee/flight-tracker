# ── .env.example ──────────────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워주세요
# cp .env.example .env
# .env 는 절대 git에 올리지 마세요! (.gitignore에 포함됨)

# SerpApi API Key (https://serpapi.com)
SERPAPI_KEY=여기에_SerpApi_Key_입력

# Discord Webhook URL (채널 편집 → 연동 → 웹후크)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/여기에_입력

# ntfy 토픽 이름 (추측하기 어렵게 고유하게 설정)
NTFY_TOPIC=bio-opo-여기에_고유이름_입력
